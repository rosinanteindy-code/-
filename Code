                message: 'ข้อมูลไม่ครบถ้วนหรือไม่ถูกต้องสำหรับแนบไฟล์'
            };
        }

        const docNumberColIndex = headers.indexOf('เลขที่ใบสั่งงาน');
        let targetColIndex = headers.indexOf(targetField);
        const lastModifiedColIndex = headers.indexOf('LastModified');

        if (targetColIndex === -1) {
            Logger.log(`Column "${targetField}" not found. Adding it.`);
            const lastCol = sheet.getLastColumn();
            sheet.getRange(1, lastCol + 1).setValue(targetField);
            targetColIndex = lastCol;
            headers.push(targetField);
        }

        if (docNumberColIndex === -1) {
            return {
                status: 'error',
                message: `ไม่พบคอลัมน์ "เลขที่ใบสั่งงาน" ใน Sheet`
            };
        }

        const allData = sheet.getRange(2, 1, sheet.getLastRow() - 1, headers.length).getValues();
        const rowIndex = allData.findIndex(row => row[docNumberColIndex] == docNumber);
        if (rowIndex === -1) {
            return {
                status: 'error',
                message: `ไม่พบใบงานเลขที่ ${docNumber}`
            };
        }

        const rowToUpdate = rowIndex + 2;

        const jobFolder = getOrCreateFolder(DriveApp.getFolderById(FOLDER_ID), docNumber);
        const newFileIds = filesData.map(fileData => {
            const prefix = targetField.replace(/\s/g, '_');
            return saveFileAndGetId(fileData, `${prefix}_${docNumber}_${Date.now()}`, jobFolder);
        }).filter(id => id);

        if (newFileIds.length === 0) {
            return {
                status: 'error',
                message: 'ไม่สามารถบันทึกไฟล์ลง Drive ได้'
            };
        }

        const existingPhotos = allData[rowIndex][targetColIndex] || '';
        const allPhotoIds = [existingPhotos, ...newFileIds].filter(id => id).join(',');

        sheet.getRange(rowToUpdate, targetColIndex + 1).setValue(allPhotoIds);
        if (lastModifiedColIndex !== -1) {
            sheet.getRange(rowToUpdate, lastModifiedColIndex + 1).setValue(new Date().toISOString());
        }

        SpreadsheetApp.flush();
        const updatedJobData = getJobDetailsByDocNumber(docNumber).data;

        return {
            status: 'success',
            message: 'แนบไฟล์เพิ่มเติมเรียบร้อย',
            updatedJob: updatedJobData
        };

    } catch (e) {
        Logger.log('ERROR in _addFilesToJob: ' + e.stack);
        return {
            status: 'error',
            message: `เกิดข้อผิดพลาดในการแนบไฟล์: ${e.message}`
        };
    } finally {
        lock.releaseLock();
    }
}

