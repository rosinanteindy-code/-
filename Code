        const historyColIndex = headers.indexOf('ActionHistory');
        const lastModifiedColIndex = headers.indexOf('LastModified');

        if (docNumberColIndex === -1 || historyColIndex === -1) {
            return { status: 'error', message: 'ไม่พบคอลัมน์ที่จำเป็นใน Sheet' };
        }

        const allData = sheet.getRange(2, 1, sheet.getLastRow() - 1, headers.length).getValues();
