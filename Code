function _deletePhoto(userEmail, docNumber, fileId) {
    const lock = LockService.getScriptLock();
    lock.waitLock(30000);
    try {
        if (!docNumber || !fileId) {
            return { status: 'error', message: 'ข้อมูลไม่ครบถ้วนสำหรับการลบรูปภาพ' };
        }

        const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
        const sheet = getOrCreateSheet(ss, SHEET_NAME, []);
        const headers = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0].map(h => h.trim());

        const docNumberColIndex = headers.indexOf('เลขที่ใบสั่งงาน');
        if (docNumberColIndex === -1) return { status: 'error', message: 'ไม่พบคอลัมน์ "เลขที่ใบสั่งงาน"' };

        const allData = sheet.getDataRange().getValues();
        const rowIndex = allData.findIndex(row => row[docNumberColIndex] == docNumber);
        if (rowIndex === -1) return { status: 'error', message: `ไม่พบใบงานเลขที่ ${docNumber}` };

        const rowToUpdate = rowIndex + 1;

        const jobPhotosColIndex = headers.indexOf('รูปงานเคลม');
        const actionPhotosColIndex = headers.indexOf('รูปภาพหลังดำเนินการ');
        const relatedDocsColIndex = headers.indexOf('RelatedDocuments');
        const lastModifiedColIndex = headers.indexOf('LastModified');

        let columnUpdated = false;
        const columnsToCheck = [jobPhotosColIndex, actionPhotosColIndex, relatedDocsColIndex];

        for (const colIndex of columnsToCheck) {
            if (colIndex !== -1) {
                let fileIds = (allData[rowIndex][colIndex] || '').toString().split(',').filter(id => id.trim());
                if (fileIds.includes(fileId)) {
                    fileIds = fileIds.filter(id => id !== fileId);
                    sheet.getRange(rowToUpdate, colIndex + 1).setValue(fileIds.join(','));
                    columnUpdated = true;
                    break;
                }
            }
        }

        if (!columnUpdated) {
            return { status: 'error', message: 'ไม่พบไฟล์ที่ระบุในใบงานนี้' };
        }

        try {
            DriveApp.getFileById(fileId).setTrashed(true);
        } catch (e) {
            Logger.log(`Could not trash file ${fileId}, but it was removed from sheet. Error: ${e.message}`);
        }

        if (lastModifiedColIndex !== -1) {
            sheet.getRange(rowToUpdate, lastModifiedColIndex + 1).setValue(new Date().toISOString());
        }

        SpreadsheetApp.flush();
        const updatedJobData = getJobDetailsByDocNumber(docNumber).data;

        return { status: 'success', message: 'ลบไฟล์เรียบร้อย', updatedJob: updatedJobData };

    } catch (e) {
        Logger.log('ERROR in _deletePhoto: ' + e.stack);
        return { status: 'error', message: `เกิดข้อผิดพลาดในการลบไฟล์: ${e.message}` };
    } finally {
        lock.releaseLock();
    }
}

