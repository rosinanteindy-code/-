function getProductDetails(productCode) {
    if (!productCode) return { status: 'error', message: 'กรุณาระบุรหัสสินค้า' };
    try {
        const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
        const sheet = ss.getSheetByName(PRODUCT_SHEET_NAME);
        if (!sheet) return { status: 'error', message: 'ไม่พบฐานข้อมูลสินค้า' };
        const data = sheet.getDataRange().getValues();
        const headers = data[0];
        const rows = data.slice(1);
        const cIdx = headers.indexOf('ProductCode'), nIdx = headers.indexOf('ProductName'), dIdx = headers.indexOf('Details');
        const p = rows.find(r => r[cIdx].toString().trim() === productCode.toString().trim());
        if (p) return { status: 'success', data: { code: p[cIdx], name: p[nIdx], details: p[dIdx] } };
        return { status: 'not_found' };
    } catch (e) { return { status: 'error', message: e.toString() }; }
}
