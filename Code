function getUserRole(email) {
    if (!email) return null;
    try {
        const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
        const sheet = getOrCreateSheet(ss, USERS_SHEET_NAME, ['Username', 'Password', 'Role', 'Status', 'FailedAttempts']);

        const data = sheet.getDataRange().getValues();
        const headers = data[0].map(h => h.trim());
        const userCol = headers.indexOf('Username');
        const roleCol = headers.indexOf('Role');
        const statusCol = headers.indexOf('Status');

        if (userCol === -1 || roleCol === -1 || statusCol === -1) return null;

        const userRow = data.find(row => row[userCol].toLowerCase() === email.toLowerCase() && row[statusCol] === 'active');

        return userRow ? userRow[roleCol] : null;
    } catch (e) {
        Logger.log('Error in getUserRole: ' + e.stack);
        return null;
    }
}

function authenticateUser(username, password) {
    const lock = LockService.getScriptLock();
    lock.waitLock(30000);
    try {
        const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
        let sheet = getOrCreateSheet(ss, USERS_SHEET_NAME, ['Username', 'Password', 'Role', 'Status', 'FailedAttempts']);

        const data = sheet.getDataRange().getValues();
        const headers = data[0].map(h => h.trim());
        const userCol = headers.indexOf('Username');
        const passCol = headers.indexOf('Password');
        const roleCol = headers.indexOf('Role');
        const statusCol = headers.indexOf('Status');
        const attemptsCol = headers.indexOf('FailedAttempts');

        if ([userCol, passCol, roleCol, statusCol, attemptsCol].includes(-1)) {
            return { status: 'error', message: 'ชีตผู้ใช้มีโครงสร้างไม่ถูกต้อง' };
        }

        const rowIndex = data.findIndex(row => row[userCol].toLowerCase() === username.toLowerCase());

        if (rowIndex === -1) {
            return { status: 'error', message: 'ไม่พบชื่อผู้ใช้นี้ในระบบ' };
        }

        const userRow = data[rowIndex];
        if (userRow[statusCol] === 'locked') {
            return { status: 'error', message: 'บัญชีของคุณถูกล็อก กรุณาติดต่อผู้ดูแลระบบ' };
        }
        if (userRow[statusCol] === 'pending') {
            return { status: 'error', message: 'บัญชีของคุณยังไม่ได้รับการอนุมัติ' };
        }
        if (userRow[statusCol] !== 'active') {
            return { status: 'error', message: 'บัญชีของคุณไม่พร้อมใช้งาน' };
        }

        if (userRow[passCol].toString() === password.toString()) {
            if (userRow[attemptsCol] > 0) {
                sheet.getRange(rowIndex + 1, attemptsCol + 1).setValue(0);
            }
            const authToken = Utilities.getUuid();
            const sessionData = {
                email: username.toLowerCase(),
                role: userRow[roleCol]
            };
            PropertiesService.getScriptProperties().setProperty(authToken, JSON.stringify(sessionData));

            return { status: 'success', role: userRow[roleCol], token: authToken, email: username.toLowerCase() };
        } else {
            let attempts = parseInt(userRow[attemptsCol], 10) || 0;
            attempts++;
            sheet.getRange(rowIndex + 1, attemptsCol + 1).setValue(attempts);

            if (attempts >= 3) {
                sheet.getRange(rowIndex + 1, statusCol + 1).setValue('locked');
                return { status: 'error', message: 'รหัสผ่านไม่ถูกต้อง บัญชีของคุณถูกล็อกแล้ว' };
            } else {
                return { status: 'error', message: `รหัสผ่านไม่ถูกต้อง (เหลือ ${3 - attempts} ครั้ง)` };
            }
        }
    } catch (e) {
        Logger.log('ERROR in authenticateUser: ' + e.stack);
        return { status: 'error', message: `เกิดข้อผิดพลาดในการยืนยันตัวตน: ${e.message}` };
    } finally {
        lock.releaseLock();
    }
}

function registerUser(email, password) {
    const lock = LockService.getScriptLock();
    lock.waitLock(30000);
    try {
        const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
        const sheet = getOrCreateSheet(ss, USERS_SHEET_NAME, ['Username', 'Password', 'Role', 'Status', 'FailedAttempts']);

        const data = sheet.getDataRange().getValues();
        const headers = data[0].map(h => h.trim());
        const userCol = headers.indexOf('Username');

        const userExists = data.some(row => row[userCol].toLowerCase() === email.toLowerCase());
        if (userExists) {
            return { status: 'error', message: 'อีเมลนี้ถูกใช้งานแล้ว' };
        }

        sheet.appendRow([email, password, 'user', 'pending', 0]);

        return { status: 'success', message: 'สมัครสมาชิกสำเร็จ' };

    } catch (e) {
        Logger.log('ERROR in registerUser: ' + e.stack);
        return { status: 'error', message: `เกิดข้อผิดพลาด: ${e.message}` };
    } finally {
        lock.releaseLock();
    }
}

function verifySession(authToken) {
    if (!authToken) {
        return { status: 'error', message: 'No token provided.' };
    }
    try {
        const cached = PropertiesService.getScriptProperties().getProperty(authToken);
        if (cached) {
            const sessionData = JSON.parse(cached);
            return { status: 'success', data: sessionData };
        } else {
            return { status: 'error', message: 'Session expired or invalid.' };
        }
    } catch (e) {
        Logger.log(`Error verifying session: ${e.message}`);
        return { status: 'error', message: `Session verification failed: ${e.message}` };
    }
}

function logoutUser(authToken) {
    if (authToken) {
        try {
            PropertiesService.getScriptProperties().deleteProperty(authToken);
        } catch (e) {
            Logger.log(`Error during logout (removing token): ${e.message}`);
        }
    }
}

