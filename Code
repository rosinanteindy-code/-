function _getAllSheetsDataForBackup(userEmail) {
    try {
        const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
        const sheets = ss.getSheets();
        const allData = {};

        sheets.forEach(sheet => {
            const name = sheet.getName();
            const range = sheet.getDataRange();
            const values = range.getValues();

            const transformedData = values.map(row =>
                row.map(cell => {
                    if (cell instanceof Date) {
                        const year = parseInt(Utilities.formatDate(cell, "Asia/Bangkok", "yyyy")) + 543;
                        return Utilities.formatDate(cell, "Asia/Bangkok", "dd/MM/") + year + Utilities.formatDate(cell, "Asia/Bangkok", " HH:mm:ss");
                    }
                    return cell;
                })
            );
            allData[name] = transformedData;
        });

        return { status: 'success', data: allData };
    } catch (e) {
        Logger.log(`Error in _getAllSheetsDataForBackup: ${e.stack}`);
        return { status: 'error', message: e.message };
    }
}

