function getSheetState() {
    try {
        const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
        const sheet = getOrCreateSheet(ss, SHEET_NAME, []);
        const headers = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0].map(h => h.trim());
        const lastModifiedColIndex = headers.indexOf('LastModified');

        let latestTimestamp = '';
        if (lastModifiedColIndex !== -1 && sheet.getLastRow() > 1) {
            const timestamps = sheet.getRange(2, lastModifiedColIndex + 1, sheet.getLastRow() - 1, 1).getValues()
                .flat()
                .filter(String);
            if (timestamps.length > 0) {
                timestamps.sort();
                latestTimestamp = timestamps[timestamps.length - 1];
            }
        }

        return {
            status: 'success',
            data: {
                rowCount: sheet.getLastRow(),
                latestTimestamp: latestTimestamp
            }
        };
    } catch (error) {
        Logger.log('ERROR in getSheetState: ' + error.stack);
        return {
            status: 'error',
            message: `Failed to get sheet state: ${error.message}`
        };
    }
}

function getRepairData() {
    try {
        const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
        const sheet = getOrCreateSheet(ss, SHEET_NAME, []);
        if (sheet.getLastRow() < 2) return {
            status: 'success',
            data: []
        };

        const values = sheet.getDataRange().getDisplayValues();
        const headers = values[0].map(h => h.trim());
        const data = values.slice(1).map(row => {
            return headers.reduce((obj, header, index) => {
                if (header) obj[header] = row[index];
                return obj;
            }, {});
        }).filter(obj => obj['เลขที่ใบสั่งงาน']);

        data.sort((a, b) => (new Date(b['วันที่แจ้ง']).getTime() || 0) - (new Date(a['วันที่แจ้ง']).getTime() || 0));

        return {
            status: 'success',
            data: data
        };
    } catch (error) {
        Logger.log('ERROR in getRepairData: ' + error.stack);
        return {
            status: 'error',
            message: `Failed to get repair data: ${error.message}`
        };
    }
}

function getEmployeeData() {
    try {
        const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
        const sheet = getOrCreateSheet(ss, EMPLOYEE_SHEET_NAME, ['Name', 'Phone', 'Status']);
        if (sheet.getLastRow() < 2) return {
            status: 'success',
            data: []
        };

        const data = sheet.getDataRange().getValues();
        const headers = data[0].map(h => h.trim());
        const nameCol = headers.indexOf('Name');
        const phoneCol = headers.indexOf('Phone');
        const statusCol = headers.indexOf('Status');

        if (nameCol === -1 || statusCol === -1) {
            return { status: 'error', message: 'Employee sheet is missing Name or Status column.' };
        }

        const employees = data.slice(1).map(row => {
            const name = row[nameCol];
            const status = row[statusCol];

            return (name && (status === 'Active' || status === '')) ? {
                name: name.trim(),
                phone: (row[phoneCol] || '').toString().trim()
            } : null;
        }).filter(Boolean);

        return {
            status: 'success',
            data: employees
        };
    } catch (error) {
        Logger.log('ERROR in getEmployeeData: ' + error.stack);
        return {
            status: 'error',
            message: `Failed to get employee data: ${error.message}`,
            data: []
        };
    }
}

function getJobDetailsByDocNumber(docNumber) {
    try {
        if (!docNumber) return { status: 'error', message: 'Document number is required.' };
        const sheet = SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName(SHEET_NAME);
        if (!sheet) throw new Error(`Sheet "${SHEET_NAME}" not found.`);

        const values = sheet.getDataRange().getDisplayValues();
        if (values.length < 2) return { status: 'error', message: 'No data found.' };

        const headers = values[0].map(h => h.trim());
        const docNumberColIndex = headers.indexOf('เลขที่ใบสั่งงาน');
        if (docNumberColIndex === -1) return { status: 'error', message: 'Document number column not found.' };

        const row = values.slice(1).find(r => r[docNumberColIndex] === docNumber);
        if (!row) return { status: 'error', message: `Job with document number ${docNumber} not found.` };

        const jobData = headers.reduce((obj, header, index) => {
            if (header) obj[header] = row[index];
            return obj;
        }, {});

        return { status: 'success', data: jobData };
    } catch (error) {
        Logger.log('ERROR in getJobDetailsByDocNumber: ' + error.stack);
        return { status: 'error', message: `Failed to get job details: ${error.message}` };
    }
}

function getDriveFileMetadata(fileIds) {
    if (!fileIds || !Array.isArray(fileIds) || fileIds.length === 0) {
        return {};
    }
    const metadata = {};
    fileIds.forEach(id => {
        try {
            const file = DriveApp.getFileById(id);
            metadata[id] = {
                mimeType: file.getMimeType(),
                thumbnailLink: file.getThumbnail() ? file.getThumbnail().getUrl() : null
            };
        } catch (e) {
            Logger.log(`Could not get metadata for file ID ${id}: ${e.message}`);
            metadata[id] = { mimeType: 'application/unknown' };
        }
    });
    return metadata;
}

function withAuthCheck(func, allowedRoles, authToken, ...args) {
    const session = verifySession(authToken);

    if (session.status !== 'success' || !session.data || !allowedRoles.includes(session.data.role)) {
        Logger.log(`Permission denied for user with token ${authToken} (session: ${JSON.stringify(session.data)}) to execute ${func.name}. Allowed: ${allowedRoles.join(', ')}`);
        return { status: 'error', message: 'Permission denied. Your session may have expired or you do not have the required role.' };
    }

    return func(session.data.email, ...args);
}
