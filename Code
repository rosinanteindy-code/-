function saveFileAndGetId(fileData, baseFilename, folder) {
    try {
        const { base64, contentType, filename: originalFilename } = fileData;
        if (!base64 || !contentType) {
            Logger.log(`Missing base64 or contentType for file.`);
            return '';
        }

        const bytes = Utilities.base64Decode(base64.split(',')[1]);
        const blob = Utilities.newBlob(bytes, contentType, `${baseFilename}_${originalFilename}`);
        const file = folder.createFile(blob);

        file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);

        return file.getId();
    } catch (e) {
        Logger.log(`Error saving file: ${e.stack}`);
        return '';
    }
}

function generateDocNumber(sheet, timestamp, prefixCode) {
    const year = String(timestamp.getFullYear() + 543).slice(-2);
    const month = ('0' + (timestamp.getMonth() + 1)).slice(-2);
    const prefix = `${prefixCode}${year}${month}-`;

    const headers = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0].map(h => h.trim());
    const docNumberColIndex = headers.indexOf("เลขที่ใบสั่งงาน");
    if (docNumberColIndex === -1) return `${prefix}0001`;

    const lastRow = sheet.getLastRow();
    if (lastRow < 2) return `${prefix}0001`;

    const docNumbers = sheet.getRange(2, docNumberColIndex + 1, lastRow - 1, 1)
        .getValues()
        .flat()
        .filter(id => typeof id === 'string' && id.startsWith(prefix))
        .map(id => parseInt(id.slice(prefix.length), 10))
        .filter(num => !isNaN(num));

    const nextNumber = docNumbers.length > 0 ? Math.max(...docNumbers) + 1 : 1;

    return `${prefix}${String(nextNumber).padStart(4, '0')}`;
}

function getOrCreateFolder(parentFolder, folderName) {
    const folders = parentFolder.getFoldersByName(folderName);
    return folders.hasNext() ? folders.next() : parentFolder.createFolder(folderName);
}

function _getUsersForManagement(userEmail, sheetType) {
    try {
        const sheetName = sheetType === 'transport' ? TRANSPORT_SHEET_NAME : EMPLOYEE_SHEET_NAME;
        const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
        const sheet = getOrCreateSheet(ss, sheetName, ['Name', 'Phone', 'Status']);

        if (sheet.getLastRow() < 2) {
            return { status: 'success', data: [] };
        }

        const values = sheet.getDataRange().getValues();
        const headers = values[0].map(h => h.trim());
        const data = values.slice(1).map((row, index) => {
            const record = headers.reduce((obj, header, i) => {
                obj[header] = row[i];
                return obj;
            }, {});
            record.originalIndex = index + 2; // Store original row number for updates
            return record;
        });

        return { status: 'success', data: data };
    } catch (e) {
        Logger.log(`Error in _getUsersForManagement (${sheetType}): ${e.stack}`);
        return { status: 'error', message: e.message };
    }
}

